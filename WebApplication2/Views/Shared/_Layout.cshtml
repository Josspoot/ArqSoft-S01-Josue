<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - JossPoot Ramen</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebApplication2.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <!-- Quitamos bg-white y navbar-light. Usamos var(--bg-card) para integrarlo al tema -->
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: var(--bg-card); border-color: #4d4f54 !important;">
        <div class="container-fluid">
            <!-- Branding temático -->
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index" style="color: var(--primary-color); font-weight: bold; font-size: 1.5rem;">
                🍜 JossPoot Ramen
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item" id="Index-Home">
                        <!-- Se reemplazó text-dark por color: var(--text-main) -->
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" style="color: var(--text-main);">Home</a>
                    </li>
                    <li class="nav-item" id="Index-About">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy" style="color: var(--text-main);">Sobre la Cocina</a>
                    </li>
                    <li class="nav-item" id="Index-Catalogo">
                        <a class="nav-link" asp-area="" asp-controller="Catalogo" asp-action="Index" style="color: var(--text-main);">Pedidos</a>
                    </li>
                </ul>
                <partial name="_LoginPartial"/>
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- Footer adaptado al tema oscuro -->
<footer class="border-top footer text-muted" style="background-color: var(--bg-card); border-color: #4d4f54 !important; position: absolute; bottom: 0; width: 100%;">
    <div class="container" style="color: var(--text-muted); text-align: center; padding: 15px 0;">
        &copy; 2026 - Josue Poot | Tecnológico de Software - <a href="https://github.com/Josspoot" target="_blank" style="color: var(--primary-color); text-decoration: none; font-weight: bold;">GitHub</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>